# JumpServer MCP — example environment configuration.
# Copy to `.env` and fill in real values. NEVER commit the filled-in .env.

# --- JumpServer connection (required) ---
# Bastion base URL (scheme + host, e.g. http://jumpserver.example.com).
JUMPSERVER_URL=http://jumpserver.example.com

# Auth: EITHER an Access Key pair (preferred) OR an API token.
ACCESS_KEY_ID=
ACCESS_KEY_SECRET=
# API_TOKEN=

# --- MCP gateway (required) ---
# Callers present this as `Authorization: Bearer <API_KEY>`.
# The MCP endpoint uses Streamable HTTP transport at BASE_PATH (default /mcp).
# Clients connect via GET/POST/DELETE on http://<host>:<SERVER_PORT><BASE_PATH>.
API_KEY=change-me
SERVER_PORT=8000
# BASE_PATH=/mcp

# --- Security / behavior tunables (optional; defaults shown) ---
POLICY_MODE=blacklist
# POLICY_CONFIG_PATH=/app/policy.json
SESSION_IDLE_TIMEOUT_SECONDS=900
MAX_CONCURRENT_JOBS=10
APPROVAL_TIMEOUT_SECONDS=300
MAX_OUTPUT_BYTES=104857600
LOG_LEVEL=INFO
